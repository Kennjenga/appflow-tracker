# AppFlow Tracker — Docker environment configuration
# Copy this file to .env.docker and fill in real values for production.
# Do NOT commit .env.docker if it contains secrets.

# Django
SECRET_KEY=change-me-use-a-long-random-string-here
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1

# Database — SQLite path inside the named volume mount
DJANGO_DB_PATH=/app/db/db.sqlite3

# Gunicorn tuning (optional)
GUNICORN_WORKERS=2
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=120
GUNICORN_LOG_LEVEL=info
